<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="800.0"
            prefWidth="900.0"
            styleClass="mainFxmlClass"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="lk.ijse.serenitymentalhealthsystem.controller.NewTherapistController">

    <stylesheets>
        <URL value="@/css/newtherapist.css"/>
    </stylesheets>

    <ScrollPane AnchorPane.topAnchor="0"
                AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0"
                fitToWidth="true">
        <VBox styleClass="form-container" spacing="0">

            <!-- Header -->
            <HBox styleClass="form-header" alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Add / Edit Therapist" styleClass="form-title"/>
                    <Label text="Enter therapist profile, professional  schedule details" styleClass="form-subtitle"/>
                </VBox>
                <Button fx:id="btnClose" text="✕" styleClass="btn-close"/>
            </HBox>

            <!-- Form Content -->
            <VBox styleClass="form-body" spacing="18">

                <!-- Therapist Info -->
                <VBox styleClass="form-section" spacing="10">
                    <Label text="Therapist Information" styleClass="section-heading"/>

                    <GridPane hgap="16" vgap="10" styleClass="input-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Therapist ID" styleClass="form-label"/>
                            <TextField fx:id="txtTherapistId" promptText="Auto or enter ID" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Full Name" styleClass="form-label"/>
                            <TextField fx:id="txtFullName" promptText="First Last" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Gender" styleClass="form-label"/>
                            <ComboBox fx:id="cmbGender" promptText="Select gender" styleClass="combo-box">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Male"/>
                                        <String fx:value="Female"/>
                                        <String fx:value="Other"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="NIC Number" styleClass="form-label"/>
                            <TextField fx:id="txtNic" promptText="901234567V" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="Date of Birth" styleClass="form-label"/>
                            <DatePicker fx:id="dpDob" styleClass="date-picker"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <Label text="Phone Number" styleClass="form-label"/>
                            <TextField fx:id="txtPhone" promptText="+94xxxxxxxxx" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                            <Label text="Email Address" styleClass="form-label"/>
                            <TextField fx:id="txtEmail" promptText="therapist@email.com" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2">
                            <Label text="Address" styleClass="form-label"/>
                            <TextField fx:id="txtAddress" promptText="Street address" styleClass="text-field"/>
                        </VBox>

                    </GridPane>
                </VBox>

                <!-- Professional Details -->
                <VBox styleClass="form-section" spacing="10">
                    <Label text="Professional Details" styleClass="section-heading"/>

                    <GridPane hgap="16" vgap="10" styleClass="input-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Specialization" styleClass="form-label"/>
                            <HBox spacing="8">
                                <CheckBox fx:id="cbCbt" text="CBT" />
                                <CheckBox fx:id="cbFamily" text="Family Counseling" />
                                <CheckBox fx:id="cbStress" text="Stress Management" />
                            </HBox>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Qualification" styleClass="form-label"/>
                            <TextField fx:id="txtQualification" promptText="e.g., MSc Psychology" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Experience (Years)" styleClass="form-label"/>
                            <TextField fx:id="txtExperience" promptText="e.g., 5" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="License Number" styleClass="form-label"/>
                            <TextField fx:id="txtLicense" promptText="License #" styleClass="text-field"/>
                        </VBox>

                    </GridPane>
                </VBox>

                <!-- Schedule Information -->
                <VBox styleClass="form-section" spacing="10">
                    <Label text="Schedule Information" styleClass="section-heading"/>

                    <GridPane hgap="16" vgap="10" styleClass="input-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Available Days" styleClass="form-label"/>
                            <ComboBox fx:id="cmbAvailableDays" promptText="Select days" styleClass="combo-box" />
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Available Time" styleClass="form-label"/>
                            <TextField fx:id="txtAvailableTime" promptText="09:00 - 16:00" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Session Capacity" styleClass="form-label"/>
                            <TextField fx:id="txtSessionCapacity" promptText="e.g., 6" styleClass="text-field"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Program Assignment" styleClass="form-label"/>
                            <ComboBox fx:id="cmbAssignProgram" promptText="Assign Therapy Program" styleClass="combo-box" />
                        </VBox>

                    </GridPane>

                    <Label text="Assigned Program List" styleClass="form-label"/>
                    <ListView fx:id="lvAssignedPrograms" prefHeight="80" styleClass="list-view" />

                </VBox>

                <!-- Status -->
                <VBox styleClass="form-section" spacing="10">
                    <Label text="Status" styleClass="section-heading"/>

                    <HBox spacing="12">
                        <Label text="Current Status" styleClass="form-label"/>
                        <ComboBox fx:id="cmbStatus" promptText="Select status" styleClass="combo-box">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="Active" />
                                    <String fx:value="Inactive" />
                                </FXCollections>
                            </items>
                        </ComboBox>
                    </HBox>
                </VBox>

            </VBox>

            <!-- Action Buttons -->
            <HBox styleClass="form-footer" spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="btnReset" text="Reset" styleClass="btn-secondary"/>
                <Button fx:id="btnSave" text="Save Therapist" styleClass="btn-primary"/>
            </HBox>

        </VBox>
    </ScrollPane>

</AnchorPane>
