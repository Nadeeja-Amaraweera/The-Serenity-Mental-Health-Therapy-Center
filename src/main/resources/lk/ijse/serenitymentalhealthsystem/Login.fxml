<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<?import java.lang.String?>
<?import java.net.URL?>
<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/25"  xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.serenitymentalhealthsystem.controller.LoginController">


    <children>
        <!-- Background Split Pane -->
        <HBox prefHeight="600.0" prefWidth="900.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <!-- Left Panel - Branding/Image Section -->
            <VBox prefWidth="400.0" styleClass="left-panel" HBox.hgrow="ALWAYS">
                <children>
                    <StackPane VBox.vgrow="ALWAYS">
                        <VBox alignment="CENTER" spacing="20">
                            <padding>
                                <Insets bottom="50" left="30" right="30" top="50" />
                            </padding>

                            <!-- Logo/Icon -->
                            <Label styleClass="logo-icon" text="🧠" />

                            <!-- Title -->
                            <Label styleClass="brand-title" text="Serenity" />
                            <Label styleClass="brand-subtitle" text="Mental Health Therapy Center" />

                            <!-- Decorative Line -->
                            <Rectangle arcHeight="5" arcWidth="5" height="3" styleClass="brand-line" width="80" />

                            <!-- Tagline -->
                            <Label styleClass="tagline" text="Healing Minds, Restoring Lives" />

                            <!-- Features List -->
                            <VBox alignment="CENTER_LEFT" spacing="15" styleClass="features">
                                <Label text="✓ Professional Therapists" />
                                <Label text="✓ Evidence-Based Treatments" />
                                <Label text="✓ Personalized Care Plans" />
                                <Label text="✓ Confidential Safe Environment" />
                            </VBox>
                        </VBox>
                    </StackPane>
                </children>
            </VBox>

            <!-- Right Panel - Login Form -->
            <VBox prefWidth="500.0" styleClass="right-panel" HBox.hgrow="ALWAYS">
                <children>
                    <StackPane VBox.vgrow="ALWAYS">
                        <VBox alignment="CENTER" maxWidth="380" spacing="25">
                            <padding>
                                <Insets bottom="20" left="40" right="40" top="20" />
                            </padding>

                            <!-- Welcome Header -->
                            <VBox alignment="CENTER" spacing="10">
                                <Label styleClass="welcome-title" text="Welcome Back!" />
                                <Label styleClass="welcome-subtitle" text="Please login to your account" />
                            </VBox>

                            <!-- Username Field -->
                            <VBox spacing="8">
                                <Label styleClass="input-label" text="Username" />
                                <TextField fx:id="usernameField" prefHeight="45" promptText="Enter your username" styleClass="input-field">
                                    <VBox.margin>
                                        <Insets />
                                    </VBox.margin>
                                </TextField>
                            </VBox>

                            <!-- Password Field -->
                            <VBox spacing="8">
                                <Label styleClass="input-label" text="Password" />
                                <PasswordField fx:id="passwordField" prefHeight="45" promptText="Enter your password" styleClass="input-field" />
                                <!-- Visible password field (hidden by default) -->
                                <TextField fx:id="visiblePasswordField" managed="false" prefHeight="45" promptText="Enter your password" styleClass="input-field" visible="false" />
                            </VBox>

                            <!-- Options Row -->
                            <HBox alignment="CENTER_LEFT" spacing="15">
                                <CheckBox fx:id="showPasswordCheckbox" styleClass="checkbox" text="Show Password" onAction="#togglePasswordVisibility"/>
                                <Region HBox.hgrow="ALWAYS" />
                                <Hyperlink styleClass="forgot-link" text="Forgot Password?" />
                            </HBox>

                            <!-- Login Button -->
                            <Button maxWidth="Infinity" onAction="#login" prefHeight="45" styleClass="login-button" text="LOGIN" />

                            <!-- Error Label -->
                            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" />

                            <!-- Loading Indicator -->
                            <ProgressIndicator fx:id="loadingIndicator" prefHeight="40" prefWidth="40" visible="false" />

                            <!-- Additional Links -->
                            <HBox alignment="CENTER" spacing="5">
                                <Label styleClass="register-text" text="Don't have an account?" />
                                <Hyperlink styleClass="register-link" text="Contact Administrator" />
                            </HBox>
                        </VBox>
                    </StackPane>
                </children>
            </VBox>
        </HBox>
    </children>
</AnchorPane>
