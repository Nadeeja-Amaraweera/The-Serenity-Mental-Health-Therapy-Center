<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane stylesheets="@/css/admindashboard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.serenitymentalhealthsystem.controller.AdminDashboardController">

    <!-- Top Header Bar -->
    <top>
        <VBox styleClass="header">
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-content">
                <padding>
                    <Insets bottom="15" left="25" right="25" top="15" />
                </padding>

                <Label styleClass="header-icon" text="🧠" />
                <Label styleClass="header-title" text="Serenity Mental Health Therapy Center" />

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="15">
                    <Label fx:id="userNameLabel" styleClass="user-name" text="Admin User" />
                    <Label fx:id="userRoleLabel" styleClass="user-role" text="(Administrator)" />
                    <Button styleClass="notification-btn" text="🔔" />
                    <Button styleClass="settings-btn" text="⚙️" />
                    <Button styleClass="logout-btn" text="🚪 Logout" />
                </HBox>
            </HBox>
        </VBox>
    </top>

    <!-- Left Sidebar Navigation -->
    <left>
        <VBox prefWidth="260" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="15" right="15" top="20" />
            </padding>

            <VBox spacing="8">
                <Label styleClass="menu-category" text="MAIN MENU" />

                <Button prefHeight="26.0" prefWidth="239.0" styleClass="sidebar-button-active" text="📊 Dashboard">
                    <graphic><Label styleClass="button-icon" text="📊" /></graphic>
                </Button>

                <Button prefHeight="26.0" prefWidth="246.0" styleClass="sidebar-button" text="👥 Patient Management">
                    <graphic><Label styleClass="button-icon" text="👥" /></graphic>
                </Button>

                <Button prefHeight="26.0" prefWidth="246.0" styleClass="sidebar-button" text="👨‍⚕️ Therapist Management">
                    <graphic><Label styleClass="button-icon" text="👨‍⚕️" /></graphic>
                </Button>

                <Button prefHeight="26.0" prefWidth="268.0" styleClass="sidebar-button" text="📚 Program Management">
                    <graphic><Label styleClass="button-icon" text="📚" /></graphic>
                </Button>

                <Button prefHeight="26.0" prefWidth="248.0" styleClass="sidebar-button" text="📅 Session Scheduling">
                    <graphic><Label styleClass="button-icon" text="📅" /></graphic>
                </Button>

                <Button prefHeight="26.0" prefWidth="242.0" styleClass="sidebar-button" text="💰 Payment Management">
                    <graphic><Label styleClass="button-icon" text="💰" /></graphic>
                </Button>

                <Button prefHeight="26.0" prefWidth="246.0" styleClass="sidebar-button" text="📈 Reports  Analytics">
                    <graphic><Label styleClass="button-icon" text="📈" /></graphic>
                </Button>

                <Separator styleClass="sidebar-separator" />

                <Label styleClass="menu-category" text="ACCOUNT" />

                <Button prefHeight="26.0" prefWidth="238.0" styleClass="sidebar-button" text="👤 My Profile">
                    <graphic><Label styleClass="button-icon" text="👤" /></graphic>
                </Button>

                <Button prefHeight="26.0" prefWidth="244.0" styleClass="sidebar-button" text="🔑 Change Password">
                    <graphic><Label styleClass="button-icon" text="🔑" /></graphic>
                </Button>
            </VBox>
        </VBox>
    </left>

    <!-- Center Content Area -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <!-- Default Dashboard View -->
            <VBox spacing="20" styleClass="dashboard-container">
                <padding>
                    <Insets bottom="25" left="25" right="25" top="25" />
                </padding>

                <!-- Welcome Banner -->
                <VBox spacing="10" styleClass="welcome-banner">
                    <Label styleClass="welcome-title" text="Welcome back, Admin!" />
                    <Label styleClass="welcome-subtitle" text="Here's what's happening with your therapy center today." />
                </VBox>

                <!-- Statistics Cards Row -->
                <HBox spacing="20" styleClass="stats-row">
                    <!-- Total Patients Card -->
                    <VBox alignment="CENTER" spacing="10" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-icon" text="👥" />
                        <Label fx:id="totalPatients" styleClass="stat-number" text="0" />
                        <Label styleClass="stat-label" text="Total Patients" />
                        <Label fx:id="patientTrend" styleClass="stat-trend positive" text="↑ 12% this month" />
                    </VBox>

                    <!-- Active Therapists Card -->
                    <VBox alignment="CENTER" spacing="10" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-icon" text="👨‍⚕️" />
                        <Label fx:id="totalTherapists" styleClass="stat-number" text="0" />
                        <Label styleClass="stat-label" text="Active Therapists" />
                        <Label fx:id="therapistTrend" styleClass="stat-trend positive" text="↑ 2 new this month" />
                    </VBox>

                    <!-- Total Revenue Card -->
                    <VBox alignment="CENTER" spacing="10" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-icon" text="💰" />
                        <Label fx:id="totalRevenue" styleClass="stat-number" text="LKR 0" />
                        <Label styleClass="stat-label" text="Total Revenue" />
                        <Label fx:id="revenueTrend" styleClass="stat-trend positive" text="↑ 18% vs last month" />
                    </VBox>

                    <!-- Today's Sessions Card -->
                    <VBox alignment="CENTER" spacing="10" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-icon" text="📅" />
                        <Label fx:id="todaySessions" styleClass="stat-number" text="0" />
                        <Label styleClass="stat-label" text="Today's Sessions" />
                        <Label fx:id="sessionTrend" styleClass="stat-trend" text="8 scheduled" />
                    </VBox>
                </HBox>

                <!-- Charts and Tables Row -->
                <HBox spacing="20" VBox.vgrow="ALWAYS">
                    <!-- Recent Registrations Table -->
                    <VBox spacing="10" styleClass="table-container" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT">
                            <Label styleClass="section-title" text="Recent Patient Registrations" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button styleClass="link-button" text="View All" />
                        </HBox>
                        <TableView fx:id="recentPatientsTable" prefHeight="300" styleClass="data-table">
                            <columns>
                                <TableColumn prefWidth="100" text="Patient ID" />
                                <TableColumn prefWidth="150" text="Name" />
                                <TableColumn prefWidth="150" text="Program" />
                                <TableColumn prefWidth="120" text="Date" />
                                <TableColumn prefWidth="80" text="Status" />
                            </columns>
                        </TableView>
                    </VBox>

                    <!-- Upcoming Sessions Table -->
                    <VBox spacing="10" styleClass="table-container" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT">
                            <Label styleClass="section-title" text="Upcoming Therapy Sessions" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button styleClass="link-button" text="Schedule" />
                        </HBox>
                        <TableView fx:id="upcomingSessionsTable" prefHeight="300" styleClass="data-table">
                            <columns>
                                <TableColumn prefWidth="100" text="Time" />
                                <TableColumn prefWidth="120" text="Patient" />
                                <TableColumn prefWidth="120" text="Therapist" />
                                <TableColumn prefWidth="130" text="Program" />
                                <TableColumn prefWidth="80" text="Room" />
                            </columns>
                        </TableView>
                    </VBox>
                </HBox>

                <!-- Payment Alerts -->
                <VBox spacing="10" styleClass="alerts-container">
                    <Label styleClass="section-title" text="Payment Alerts" />
                    <ListView fx:id="paymentAlerts" prefHeight="100" styleClass="alerts-list" />
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
