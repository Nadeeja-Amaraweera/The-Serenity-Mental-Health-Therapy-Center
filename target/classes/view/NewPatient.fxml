<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="780.0"
            prefWidth="1180.0"
            styleClass="mainFxmlClass"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/25"
            fx:controller="lk.ijse.serenitymentalhealthsystem.controller.NewPatientController">

    <stylesheets>
        <URL value="@/css/newpatient.css"/>
    </stylesheets>

    <ScrollPane AnchorPane.topAnchor="0"
                AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0"
                AnchorPane.rightAnchor="0"
                fitToWidth="true">
        <VBox styleClass="form-container" spacing="0">

            <!-- Header -->
            <HBox styleClass="form-header" alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="3" HBox.hgrow="ALWAYS">
                    <Label text="Add / Edit Patient" styleClass="form-title"/>
                    <Label text="Fill in patient details to create a new record" styleClass="form-subtitle"/>
                </VBox>
                <Button fx:id="btnClose" text="✕" styleClass="btn-close"/>
            </HBox>

            <!-- Form Content -->
            <VBox styleClass="form-body" spacing="20">

                <!-- Personal Information Section -->
                <VBox styleClass="form-section" spacing="12">
                    <Label text="Personal Information" styleClass="section-heading"/>

                    <GridPane hgap="16" vgap="10" styleClass="input-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- First Name -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="First Name" styleClass="form-label"/>
                            <TextField fx:id="txtFirstName" promptText="Enter first name" styleClass="text-field"/>
                        </VBox>

                        <!-- Last Name -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Last Name" styleClass="form-label"/>
                            <TextField fx:id="txtLastName" promptText="Enter last name" styleClass="text-field"/>
                        </VBox>

                        <!-- Date of Birth -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Date of Birth" styleClass="form-label"/>
                            <DatePicker fx:id="dpDateOfBirth" styleClass="date-picker"/>
                        </VBox>

                        <!-- Gender -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Gender" styleClass="form-label"/>
                            <ComboBox fx:id="cmbGender" promptText="Select gender" styleClass="combo-box">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Male"/>
                                        <String fx:value="Female"/>
                                        <String fx:value="Other"/>
                                        <String fx:value="Prefer Not to Say"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Contact Information Section -->
                <VBox styleClass="form-section" spacing="12">
                    <Label text="Contact Information" styleClass="section-heading"/>

                    <GridPane hgap="16" vgap="10" styleClass="input-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Email -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Email Address" styleClass="form-label"/>
                            <TextField fx:id="txtEmail" promptText="example@email.com" styleClass="text-field"/>
                        </VBox>

                        <!-- Phone -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Phone Number" styleClass="form-label"/>
                            <TextField fx:id="txtPhone" promptText="+1 (555) 000-0000" styleClass="text-field"/>
                        </VBox>

                        <!-- Address -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                            <Label text="Address" styleClass="form-label"/>
                            <TextField fx:id="txtAddress" promptText="Street address" styleClass="text-field"/>
                        </VBox>

                        <!-- City -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="City" styleClass="form-label"/>
                            <TextField fx:id="txtCity" promptText="City" styleClass="text-field"/>
                        </VBox>

                        <!-- State/Province -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <Label text="State/Province" styleClass="form-label"/>
                            <TextField fx:id="txtState" promptText="State" styleClass="text-field"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Medical Information Section -->
                <VBox styleClass="form-section" spacing="12">
                    <Label text="Medical Information" styleClass="section-heading"/>

                    <GridPane hgap="16" vgap="10" styleClass="input-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Blood Type -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Blood Type" styleClass="form-label"/>
                            <ComboBox fx:id="cmbBloodType" promptText="Select blood type" styleClass="combo-box">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="A+"/>
                                        <String fx:value="A-"/>
                                        <String fx:value="B+"/>
                                        <String fx:value="B-"/>
                                        <String fx:value="O+"/>
                                        <String fx:value="O-"/>
                                        <String fx:value="AB+"/>
                                        <String fx:value="AB-"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>

                        <!-- Allergies -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Known Allergies" styleClass="form-label"/>
                            <TextField fx:id="txtAllergies" promptText="e.g., Penicillin, Peanuts" styleClass="text-field"/>
                        </VBox>

                        <!-- Medical History -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                            <Label text="Medical History" styleClass="form-label"/>
                            <TextArea fx:id="taMedicalHistory" promptText="Enter past medical conditions, surgeries, medications..." wrapText="true" prefRowCount="4" styleClass="text-area"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Therapy Information Section -->
                <VBox styleClass="form-section" spacing="12">
                    <Label text="Therapy Information" styleClass="section-heading"/>

                    <GridPane hgap="16" vgap="10" styleClass="input-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Primary Concern -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                            <Label text="Primary Concern / Reason for Visit" styleClass="form-label"/>
                            <TextField fx:id="txtPrimaryConcern" promptText="e.g., Anxiety, Depression, Stress Management" styleClass="text-field"/>
                        </VBox>

                        <!-- Therapy Type -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Preferred Therapy Type" styleClass="form-label"/>
                            <ComboBox fx:id="cmbTherapyType" promptText="Select therapy type" styleClass="combo-box">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Cognitive Behavioral Therapy"/>
                                        <String fx:value="Psychotherapy"/>
                                        <String fx:value="Counseling"/>
                                        <String fx:value="Family Therapy"/>
                                        <String fx:value="Group Therapy"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>

                        <!-- Status -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Initial Status" styleClass="form-label"/>
                            <ComboBox fx:id="cmbStatus" promptText="Select status" styleClass="combo-box">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Active"/>
                                        <String fx:value="Inactive"/>
                                        <String fx:value="On Hold"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>

                        <!-- Additional Notes -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2">
                            <Label text="Additional Notes" styleClass="form-label"/>
                            <TextArea fx:id="taNotes" promptText="Any additional information or notes..." wrapText="true" prefRowCount="3" styleClass="text-area"/>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- Emergency Contact Section -->
                <VBox styleClass="form-section" spacing="12">
                    <Label text="Emergency Contact" styleClass="section-heading"/>

                    <GridPane hgap="16" vgap="10" styleClass="input-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <!-- Emergency Contact Name -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Contact Name" styleClass="form-label"/>
                            <TextField fx:id="txtEmergencyName" promptText="Full name" styleClass="text-field"/>
                        </VBox>

                        <!-- Emergency Contact Phone -->
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Contact Phone" styleClass="form-label"/>
                            <TextField fx:id="txtEmergencyPhone" promptText="Phone number" styleClass="text-field"/>
                        </VBox>

                        <!-- Relationship -->
                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Relationship" styleClass="form-label"/>
                            <TextField fx:id="txtRelationship" promptText="e.g., Parent, Spouse, Friend" styleClass="text-field"/>
                        </VBox>
                    </GridPane>
                </VBox>

            </VBox>

            <!-- Action Buttons -->
            <HBox styleClass="form-footer" spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="btnCancel" text="Cancel" styleClass="btn-secondary"/>
                <Button fx:id="btnReset" text="Reset" styleClass="btn-secondary"/>
                <Button fx:id="btnSave" text="Save Patient" styleClass="btn-primary"/>
            </HBox>

        </VBox>
    </ScrollPane>

</AnchorPane>
