<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" prefHeight="780.0" prefWidth="1180.0" styleClass="mainFxmlClass" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.serenitymentalhealthsystem.controller.TherapistManagementController">

    <stylesheets>
        <URL value="@/css/therapistmanagement.css" />
        <URL value="@/css/patientmanagement.css" />
    </stylesheets>

    <!-- ╔══════════════════════════════════════════════════════════════════╗
         ║  Root StackPane — anchored to fill the AnchorPane               ║
         ║  Allows dynamic loading of different views                      ║
         ╚══════════════════════════════════════════════════════════════════╝ -->
    <StackPane fx:id="mainStackPane" styleClass="root-pane" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- ╔══════════════════════════════════╗
             ║  MAIN CONTENT LAYER              ║
             ╚══════════════════════════════════╝ -->
        <BorderPane fx:id="mainContentPane" styleClass="content-container">

            <!-- CENTER: Therapist list and detail -->
            <center>
                <VBox spacing="0" styleClass="content-area">

                    <!-- Page header + stat chips -->
                    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="top-header">
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label styleClass="page-title" text="Therapist Management" />
                            <Label styleClass="page-subtitle" text="Manage therapist profiles, specializations &amp; availability" />
                        </VBox>

                        <HBox alignment="CENTER" spacing="10">
                            <VBox alignment="CENTER" spacing="2" styleClass="stat-chip chip-blue">
                                <Label fx:id="lblTotalTherapists" styleClass="stat-value" text="0" />
                                <Label styleClass="stat-label" text="Total Therapists" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="2" styleClass="stat-chip chip-green">
                                <Label fx:id="lblAvailableTherapists" styleClass="stat-value" text="0" />
                                <Label styleClass="stat-label" text="Available" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="2" styleClass="stat-chip chip-amber">
                                <Label fx:id="lblBusyTherapists" styleClass="stat-value" text="0" />
                                <Label styleClass="stat-label" text="Busy" />
                            </VBox>
                        </HBox>
                    </HBox>

                    <!-- Toolbar: search · filters · actions -->
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar">

                        <StackPane styleClass="search-wrap" HBox.hgrow="ALWAYS">
                            <Label styleClass="search-icon" text="⌕" />
                            <TextField fx:id="txtSearch" promptText="Search by name, email or phone…" styleClass="search-field" />
                        </StackPane>

                        <ComboBox fx:id="cmbSpecializationFilter" promptText="All Specializations" styleClass="filter-combo" />

                        <ComboBox fx:id="cmbAvailabilityFilter" promptText="All Availability" styleClass="filter-combo">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="All" />
                                    <String fx:value="Available" />
                                    <String fx:value="Busy" />
                                    <String fx:value="On Leave" />
                                </FXCollections>
                            </items>
                        </ComboBox>

                        <Separator orientation="VERTICAL" styleClass="toolbar-sep" />

                        <Button fx:id="btnExport" styleClass="btn-secondary" text="↑  Export" />

                        <Button fx:id="btnAddTherapist" onAction="#AddNewTherapist" styleClass="btn-primary" text="+  Add Therapist" />
                    </HBox>

                    <!-- Therapist table (styled like Patient table) -->
                    <StackPane styleClass="table-wrapper" VBox.vgrow="ALWAYS">
                        <TableView fx:id="tblTherapists" styleClass="patient-table">
                            <columns>

                                <TableColumn fx:id="colId" maxWidth="85" minWidth="75" text="ID">
                                    <cellValueFactory><PropertyValueFactory property="therapistId" /></cellValueFactory>
                                </TableColumn>

                                <TableColumn fx:id="colName" minWidth="170" prefWidth="195" text="NAME">
                                    <cellValueFactory><PropertyValueFactory property="fullName" /></cellValueFactory>
                                </TableColumn>

                                <TableColumn fx:id="colSpecialization" minWidth="150" prefWidth="170" text="SPECIALIZATION">
                                    <cellValueFactory><PropertyValueFactory property="specialization" /></cellValueFactory>
                                </TableColumn>

                                <TableColumn fx:id="colPrograms" minWidth="130" prefWidth="150" text="ASSIGNED PROGRAM">
                                    <cellValueFactory><PropertyValueFactory property="assignedProgram" /></cellValueFactory>
                                </TableColumn>

                                <TableColumn fx:id="colPhone" minWidth="130" prefWidth="150" text="PHONE">
                                    <cellValueFactory><PropertyValueFactory property="phone" /></cellValueFactory>
                                </TableColumn>

                                <TableColumn fx:id="colAvailability" minWidth="110" prefWidth="130" text="AVAILABILITY">
                                    <cellValueFactory><PropertyValueFactory property="availability" /></cellValueFactory>
                                </TableColumn>

                                <TableColumn fx:id="colStatus" maxWidth="105" minWidth="90" text="STATUS">
                                    <cellValueFactory><PropertyValueFactory property="status" /></cellValueFactory>
                                </TableColumn>

                                <TableColumn fx:id="colActions" maxWidth="128" minWidth="115" sortable="false" text="ACTIONS">
                                    <cellValueFactory><PropertyValueFactory property="actions" /></cellValueFactory>
                                </TableColumn>

                            </columns>

                            <placeholder>
                                <VBox alignment="CENTER" spacing="12" styleClass="table-empty">
                                    <Label styleClass="empty-icon" text="◎" />
                                    <Label styleClass="empty-title" text="No therapists found" />
                                    <Label styleClass="empty-sub" text="Try adjusting your search or filters" />
                                </VBox>
                            </placeholder>
                        </TableView>
                    </StackPane>

                    <!-- Footer: row count + pagination -->
                    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="footer-bar">

                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="5">
                            <Button fx:id="btnFirstPage" styleClass="page-btn" text="«" />
                            <Button fx:id="btnPrevPage" styleClass="page-btn" text="‹" />
                            <Label fx:id="lblCurrentPage" styleClass="page-current" text="1" />
                            <Label styleClass="page-of" text="of" />
                            <Label fx:id="lblTotalPages" styleClass="page-total" text="10" />
                            <Button fx:id="btnNextPage" styleClass="page-btn" text="›" />
                            <Button fx:id="btnLastPage" styleClass="page-btn" text="»" />
                        </HBox>
                        <ComboBox fx:id="cmbRowsPerPage" styleClass="rows-combo">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="10 rows" />
                                    <String fx:value="20 rows" />
                                    <String fx:value="50 rows" />
                                    <String fx:value="100 rows" />
                                </FXCollections>
                            </items>
                            <value><String fx:value="20 rows" /></value>
                        </ComboBox>
                    </HBox>

                </VBox>
            </center>

            <!-- ╔══════════════════════════════════╗
                 ║  RIGHT — DETAIL SLIDE PANEL      ║
                 ╚══════════════════════════════════╝ -->
            <right>
                <VBox fx:id="detailPanel" managed="false" maxWidth="330" minWidth="310" spacing="0" styleClass="detail-panel" visible="false">

                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="detail-header">
                        <Label styleClass="detail-title" text="Therapist Details" HBox.hgrow="ALWAYS" />
                        <Button styleClass="close-detail-btn" text="✕" />
                    </HBox>

                    <ScrollPane fitToWidth="true" styleClass="detail-scroll" VBox.vgrow="ALWAYS">
                        <VBox spacing="18" styleClass="detail-body">

                            <!-- Avatar -->
                            <VBox alignment="CENTER" spacing="8" styleClass="detail-avatar-block">
                                <StackPane styleClass="detail-avatar">
                                    <Label fx:id="lblDetailInitials" styleClass="detail-initials" text="TH" />
                                </StackPane>
                                <Label fx:id="lblDetailName" styleClass="detail-name" text="Therapist Name" />
                                <Label fx:id="lblDetailId" styleClass="detail-pid" text="THR-00001" />
                                <Label fx:id="lblDetailStatus" styleClass="detail-status-active" text="● Available" />
                            </VBox>

                            <Separator styleClass="detail-sep" />

                            <!-- Contact info -->
                            <VBox spacing="10" styleClass="detail-section">
                                <Label styleClass="detail-section-title" text="CONTACT INFORMATION" />

                                <HBox alignment="TOP_LEFT" spacing="8" styleClass="detail-field">
                                    <Label styleClass="field-icon" text="✉" />
                                    <VBox spacing="1">
                                        <Label styleClass="field-label" text="Email" />
                                        <Label fx:id="lblDetailEmail" styleClass="field-value" text="therapist@email.com" />
                                    </VBox>
                                </HBox>

                                <HBox alignment="TOP_LEFT" spacing="8" styleClass="detail-field">
                                    <Label styleClass="field-icon" text="☏" />
                                    <VBox spacing="1">
                                        <Label styleClass="field-label" text="Phone" />
                                        <Label fx:id="lblDetailPhone" styleClass="field-value" text="+94761234567" />
                                    </VBox>
                                </HBox>
                            </VBox>

                            <Separator styleClass="detail-sep" />

                            <!-- Professional info -->
                            <VBox spacing="10" styleClass="detail-section">
                                <Label styleClass="detail-section-title" text="PROFESSIONAL INFORMATION" />

                                <HBox alignment="TOP_LEFT" spacing="8" styleClass="detail-field">
                                    <Label styleClass="field-icon" text="◈" />
                                    <VBox spacing="1" HBox.hgrow="ALWAYS">
                                        <Label styleClass="field-label" text="Specialization" />
                                        <Label fx:id="lblDetailSpecialization" styleClass="field-value" text="Cognitive Behavioral Therapy" wrapText="true" />
                                    </VBox>
                                </HBox>

                                <HBox alignment="TOP_LEFT" spacing="8" styleClass="detail-field">
                                    <Label styleClass="field-icon" text="◉" />
                                    <VBox spacing="1">
                                        <Label styleClass="field-label" text="Availability" />
                                        <Label fx:id="lblDetailAvailability" styleClass="field-value" text="Available" />
                                    </VBox>
                                </HBox>

                                <HBox alignment="TOP_LEFT" spacing="8" styleClass="detail-field">
                                    <Label styleClass="field-icon" text="◣" />
                                    <VBox spacing="1">
                                        <Label styleClass="field-label" text="Assigned Program" />
                                        <Label fx:id="lblDetailProgram" styleClass="field-value" text="Anxiety Management" />
                                    </VBox>
                                </HBox>
                            </VBox>

                            <Separator styleClass="detail-sep" />

                            <!-- Detail action buttons -->
                            <VBox spacing="8" styleClass="detail-actions">
                                <Button maxWidth="Infinity" styleClass="btn-primary" text="✎   Edit Therapist" />
                                <Button maxWidth="Infinity" styleClass="btn-secondary" text="◉   Change Availability" />
                                <Button maxWidth="Infinity" styleClass="btn-ghost" text="◷   View Schedule" />
                                <Button maxWidth="Infinity" styleClass="btn-danger" text="✕   Remove Therapist" />
                            </VBox>

                        </VBox>
                    </ScrollPane>

                </VBox>
            </right>

        </BorderPane>

        <!-- ╔══════════════════════════════════════════════════════════════════╗
             ║  OVERLAY LAYER — Reserved for dynamic view loading              ║
             ║  Developers can load additional StackPanes on top of main view   ║
             ║  Usage: mainStackPane.getChildren().add(dynamicStackPane)        ║
             ╚══════════════════════════════════════════════════════════════════╝ -->
        <StackPane fx:id="overlayStackPane" managed="false" visible="false" styleClass="overlay-layer" />

    </StackPane>

</AnchorPane>
